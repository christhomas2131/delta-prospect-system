# Delta Prospect System — Environment Variables
# Copy to .env for local development. On Railway, set these in the dashboard.

# Database connection (Railway provides this automatically)
# For local dev with individual params:
DB_HOST=localhost
DB_PORT=5432
DB_NAME=delta_prospect
DB_USER=delta
DB_PASSWORD=delta_dev
# Or use a full connection string (takes priority over individual params):
# DATABASE_URL=postgresql://delta:delta_dev@localhost:5432/delta_prospect

# Server port (Railway sets this automatically — do not hardcode in production)
PORT=8000

# Authentication (leave blank to disable auth for local dev)
AUTH_USER=
AUTH_PASSWORD=

# CORS (comma-separated origins, or * for dev)
ALLOWED_ORIGINS=*

# Optional: Anthropic API key for Deep Analysis feature
ANTHROPIC_API_KEY=

# Cron endpoint secret (protects /api/cron/enrich-all from unauthorized access)
CRON_SECRET=
