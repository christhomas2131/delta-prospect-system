# Delta Prospect System — Environment Configuration
# Copy to .env and update if needed

# Database (matches Docker defaults — change for production)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=delta_prospect
DB_USER=delta
DB_PASSWORD=delta_dev

# App
APP_HOST=0.0.0.0
APP_PORT=8000

# Auth (optional — leave blank for no password protection)
# AUTH_USER=admin
# AUTH_PASSWORD=changeme

# CORS (comma-separated origins, default * allows all)
# ALLOWED_ORIGINS=https://yourdomain.com
